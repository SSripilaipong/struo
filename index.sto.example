# Example struo collection
F = a->b
G = fog: a->c
Fs = {f: a->b, g: b->c}
Xs = {a, b, c}
MyGraph = graph{objects: {a,b,c}, arrows: {f: a->b, g: b->c, fog: a->c, d->e}}

# Nested graphs: graphs as objects, arrows with body
Src = graph{ objects: {a, b, c}, arrows: {a->b, b->c} }
Dst = graph{ objects: {d, e}, arrows: {d->e} }
Assoc = {u: a->d, v: c->e}
Composed = graph{
    objects: {g: Src, h: Dst},
    arrows: {f: g->h: Assoc}
}
